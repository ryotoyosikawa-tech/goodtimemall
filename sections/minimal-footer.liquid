{{ 'minimal-footer.css' | asset_url | stylesheet_tag }}

<section class="minimal-footer"
         style="padding-top: {{ section.settings.padding_top }}px;
                padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="minimal-footer__grain" aria-hidden="true"></div>

  <div class="minimal-footer__inner">

    {%- comment -%} Logo & Brand {%- endcomment -%}
    <div class="minimal-footer__logo-area">
      {%- if section.settings.logo != blank -%}
        <img class="minimal-footer__logo"
             src="{{ section.settings.logo | image_url: width: 240 }}"
             alt="{{ shop.name | escape }}"
             width="120"
             height="120" />
      {%- endif -%}

      <h2 class="minimal-footer__brand-name">
        {{ section.settings.brand_name | default: shop.name | escape }}
      </h2>

      {%- if section.settings.tagline != blank -%}
        <p class="minimal-footer__tagline">{{ section.settings.tagline | escape }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Divider {%- endcomment -%}
    <div class="minimal-footer__divider" aria-hidden="true"></div>

    {%- comment -%} Navigation Links {%- endcomment -%}
    {%- if section.settings.menu != blank -%}
      {%- assign footer_menu = linklists[section.settings.menu] -%}
      {%- if footer_menu.links.size > 0 -%}
        <nav class="minimal-footer__links" aria-label="Footer navigation">
          {%- for link in footer_menu.links -%}
            <a href="{{ link.url }}" class="minimal-footer__link">
              {{ link.title | escape }}
            </a>
          {%- endfor -%}
        </nav>
      {%- endif -%}
    {%- endif -%}

    {%- comment -%} Social Icons {%- endcomment -%}
    {%- if section.settings.show_social -%}
      <div class="minimal-footer__social">
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" class="minimal-footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <circle cx="12" cy="12" r="5"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if settings.social_twitter_link != blank -%}
          <a href="{{ settings.social_twitter_link }}" class="minimal-footer__social-link" aria-label="X / Twitter" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if settings.social_tiktok_link != blank -%}
          <a href="{{ settings.social_tiktok_link }}" class="minimal-footer__social-link" aria-label="TikTok" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.73a8.19 8.19 0 004.76 1.52v-3.4a4.85 4.85 0 01-1-.16z"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if settings.social_youtube_link != blank -%}
          <a href="{{ settings.social_youtube_link }}" class="minimal-footer__social-link" aria-label="YouTube" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.5 6.19a3.02 3.02 0 00-2.12-2.14C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.38.55A3.02 3.02 0 00.5 6.19 31.66 31.66 0 000 12a31.66 31.66 0 00.5 5.81 3.02 3.02 0 002.12 2.14c1.88.55 9.38.55 9.38.55s7.5 0 9.38-.55a3.02 3.02 0 002.12-2.14A31.66 31.66 0 0024 12a31.66 31.66 0 00-.5-5.81zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Brand Partner CTA {%- endcomment -%}
    {%- if section.settings.show_partner_cta -%}
      <div class="minimal-footer__divider" aria-hidden="true" style="margin-top: 8px;"></div>
      <div class="minimal-footer__partner">
        <p class="minimal-footer__partner-label">{{ section.settings.partner_label | escape }}</p>
        <a href="{{ section.settings.partner_link }}" class="minimal-footer__partner-btn">
          {{ section.settings.partner_btn_text | escape }}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M5 2.5L9.5 7L5 11.5" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    {%- endif -%}

    {%- comment -%} Copyright {%- endcomment -%}
    <p class="minimal-footer__copyright">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name | escape }}. All rights reserved.
    </p>

  </div>
</section>

{% schema %}
{
  "name": "Minimal Footer",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand Name",
      "default": "GoodTimeMall"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Fun time to choose clothes"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Footer menu",
      "default": "footer"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social icons",
      "default": true,
      "info": "Social links are configured in Theme Settings > Social media"
    },
    {
      "type": "header",
      "content": "Brand Partner CTA"
    },
    {
      "type": "checkbox",
      "id": "show_partner_cta",
      "label": "Show partner invitation",
      "default": true
    },
    {
      "type": "text",
      "id": "partner_label",
      "label": "Partner label text",
      "default": "ご出展を希望の企業様・ブランド様"
    },
    {
      "type": "text",
      "id": "partner_btn_text",
      "label": "Partner button text",
      "default": "お問い合わせはこちら"
    },
    {
      "type": "url",
      "id": "partner_link",
      "label": "Partner link",
      "info": "Link to contact page"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Minimal Footer"
    }
  ]
}
{% endschema %}
