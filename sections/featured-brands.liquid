{{ 'featured-brands.css' | asset_url | stylesheet_tag }}

<section class="featured-brands"
         style="padding-top: {{ section.settings.padding_top }}px;
                padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="featured-brands__inner">

    {%- comment -%} Section Header + Nav Arrows {%- endcomment -%}
    <div class="featured-brands__header">
      <div class="featured-brands__header-text">
        {%- if section.settings.heading != blank -%}
          <h2 class="featured-brands__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="featured-brands__subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
      <div class="featured-brands__nav">
        <button class="featured-brands__nav-btn featured-brands__nav-prev" aria-label="Previous">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M13 4L7 10L13 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
        <button class="featured-brands__nav-btn featured-brands__nav-next" aria-label="Next">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M7 4L13 10L7 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>

    {%- comment -%} Brand Cards Slider {%- endcomment -%}
    <div class="featured-brands__slider" id="brandsSlider-{{ section.id }}">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}"
           class="featured-brands__card"
           aria-label="Visit {{ block.settings.name | escape }}"
           {{ block.shopify_attributes }}>

          {%- comment -%} Image {%- endcomment -%}
          <div class="featured-brands__image-wrapper">
            {%- if block.settings.image != blank -%}
              <img class="featured-brands__image"
                   src="{{ block.settings.image | image_url: width: 800 }}"
                   alt="{{ block.settings.name | escape }}"
                   loading="lazy"
                   width="800"
                   height="500" />
            {%- else -%}
              <div class="featured-brands__placeholder">
                <span>+</span>
              </div>
            {%- endif -%}
          </div>

          {%- comment -%} Info {%- endcomment -%}
          <div class="featured-brands__info">
            <div class="featured-brands__text">
              <span class="featured-brands__name">{{ block.settings.name | escape }}</span>
              {%- if block.settings.description != blank -%}
                <p class="featured-brands__description">{{ block.settings.description | escape }}</p>
              {%- endif -%}
            </div>
            <span class="featured-brands__arrow" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
        </a>
      {%- endfor -%}
    </div>

  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var section = document.getElementById('shopify-section-{{ section.id }}');
  if (!section) return;

  var slider = document.getElementById('brandsSlider-{{ section.id }}');
  var cards = slider.querySelectorAll('.featured-brands__card');
  if (cards.length === 0) return;

  // --- Scroll reveal animation ---
  var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (prefersReducedMotion) {
    cards.forEach(function(card) { card.classList.add('is-visible'); });
  } else {
    var appearObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var card = entry.target;
          var index = Array.from(cards).indexOf(card);
          var delay = Math.min(index * 150, 600);
          setTimeout(function() { card.classList.add('is-visible'); }, delay);
          appearObserver.unobserve(card);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

    cards.forEach(function(card) { appearObserver.observe(card); });
  }

  // --- Navigation arrows ---
  var prevBtn = section.querySelector('.featured-brands__nav-prev');
  var nextBtn = section.querySelector('.featured-brands__nav-next');

  if (prevBtn && nextBtn) {
    var getScrollAmount = function() {
      var firstCard = slider.querySelector('.featured-brands__card');
      if (!firstCard) return 300;
      return firstCard.offsetWidth + 24;
    };

    nextBtn.addEventListener('click', function() {
      slider.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    });

    prevBtn.addEventListener('click', function() {
      slider.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    });
  }
});
</script>

{% schema %}
{
  "name": "Featured Brands",
  "tag": "section",
  "class": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FEATURED BRANDS"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover the brands that define Good Time Mall"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Brand Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Brand Name",
          "default": "BRAND NAME"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Short brand description goes here."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link to brand collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Brands",
      "blocks": [
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" }
      ]
    }
  ]
}
{% endschema %}
