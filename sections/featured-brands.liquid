{{ 'featured-brands.css' | asset_url | stylesheet_tag }}

<section class="featured-brands"
         style="padding-top: {{ section.settings.padding_top }}px;
                padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="featured-brands__inner">

    {%- comment -%} Section Header {%- endcomment -%}
    <div class="featured-brands__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="featured-brands__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="featured-brands__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Brand Cards Grid {%- endcomment -%}
    <div class="featured-brands__grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}"
           class="featured-brands__card"
           aria-label="Visit {{ block.settings.name | escape }}"
           {{ block.shopify_attributes }}>

          {%- comment -%} Image {%- endcomment -%}
          <div class="featured-brands__image-wrapper">
            {%- if block.settings.image != blank -%}
              <img class="featured-brands__image"
                   src="{{ block.settings.image | image_url: width: 800 }}"
                   alt="{{ block.settings.name | escape }}"
                   loading="lazy"
                   width="800"
                   height="500" />
            {%- else -%}
              <div class="featured-brands__placeholder">
                <span>+</span>
              </div>
            {%- endif -%}
          </div>

          {%- comment -%} Info {%- endcomment -%}
          <div class="featured-brands__info">
            <div class="featured-brands__text">
              <span class="featured-brands__name">{{ block.settings.name | escape }}</span>
              {%- if block.settings.description != blank -%}
                <p class="featured-brands__description">{{ block.settings.description | escape }}</p>
              {%- endif -%}
            </div>
            <span class="featured-brands__arrow" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
        </a>
      {%- endfor -%}
    </div>

  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var cards = document.querySelectorAll('#shopify-section-{{ section.id }} .featured-brands__card');
  if (cards.length === 0) return;

  var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (prefersReducedMotion) {
    cards.forEach(function(card) { card.classList.add('is-visible'); });
    return;
  }

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        var card = entry.target;
        var index = Array.from(cards).indexOf(card);
        var delay = Math.min(index * 150, 450);

        setTimeout(function() {
          card.classList.add('is-visible');
        }, delay);

        observer.unobserve(card);
      }
    });
  }, {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  });

  cards.forEach(function(card) {
    observer.observe(card);
  });
});
</script>

{% schema %}
{
  "name": "Featured Brands",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FEATURED BRANDS"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover the brands that define Good Time Mall"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Brand Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Brand Name",
          "default": "BRAND NAME"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Short brand description goes here."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link to brand collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Brands",
      "blocks": [
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" }
      ]
    }
  ]
}
{% endschema %}
