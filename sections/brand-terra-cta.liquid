<section class="brand-terra terra-cta" id="terraCta-{{ section.id }}">
  <div class="terra-noise" aria-hidden="true" style="position: relative;"></div>
  <h2 class="terra-cta__title">{{ section.settings.heading | default: 'Discover TERRA' | escape }}</h2>
  <a href="{{ collection.url }}" class="terra-cta__btn">
    {{ section.settings.button_text | default: 'View Collection' | escape }} &rarr;
  </a>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var el = document.getElementById('terraCta-{{ section.id }}');
  if (!el) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    el.classList.add('is-visible'); return;
  }
  new IntersectionObserver(function(entries, obs) {
    entries.forEach(function(e) {
      if (e.isIntersecting) { e.target.classList.add('is-visible'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.2 }).observe(el);
});
</script>

{% schema %}
{
  "name": "TERRA CTA",
  "tag": "div",
  "class": "brand-terra-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Discover TERRA"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "View Collection"
    }
  ],
  "presets": [
    {
      "name": "TERRA CTA"
    }
  ]
}
{% endschema %}
