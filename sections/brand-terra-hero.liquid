{{ 'brand-terra.css' | asset_url | stylesheet_tag }}

<section class="brand-terra terra-hero" id="terraHero-{{ section.id }}">
  <div class="terra-noise" aria-hidden="true"></div>
  <div class="terra-hero__content">
    <div class="terra-hero__icon">
      <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="0.6">
        <circle cx="16" cy="16" r="10"/><circle cx="16" cy="16" r="6"/><circle cx="16" cy="16" r="2.5"/>
        <line x1="16" y1="3" x2="16" y2="29"/><line x1="3" y1="16" x2="29" y2="16"/>
      </svg>
    </div>
    <h1 class="terra-hero__name">{{ section.settings.brand_name | default: 'TERRA' | escape }}</h1>
    <p class="terra-hero__sub">{{ section.settings.sub_text | default: 'Clothing & Textiles' | escape }}</p>
    <div class="terra-hero__divider"></div>
    <p class="terra-hero__year">{{ section.settings.year_text | default: 'Est. 2024' | escape }}</p>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var hero = document.getElementById('terraHero-{{ section.id }}');
  if (!hero) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    hero.classList.add('is-visible'); return;
  }
  setTimeout(function() { hero.classList.add('is-visible'); }, 200);
});
</script>

{% schema %}
{
  "name": "TERRA Hero",
  "tag": "div",
  "class": "brand-terra-section",
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "TERRA"
    },
    {
      "type": "text",
      "id": "sub_text",
      "label": "Sub text",
      "default": "Clothing & Textiles"
    },
    {
      "type": "text",
      "id": "year_text",
      "label": "Year text",
      "default": "Est. 2024"
    }
  ],
  "presets": [
    {
      "name": "TERRA Hero"
    }
  ]
}
{% endschema %}
