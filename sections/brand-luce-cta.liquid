<section class="brand-luce luce-cta" id="luceCta-{{ section.id }}">
  <h2 class="luce-cta__title">{{ section.settings.heading | default: 'Explore the full collection' | escape }}</h2>
  <a href="{{ collection.url }}" class="luce-cta__btn">
    {{ section.settings.button_text | default: 'Shop LUCE' | escape }} &rarr;
  </a>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var el = document.getElementById('luceCta-{{ section.id }}');
  if (!el) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    el.classList.add('is-visible'); return;
  }
  new IntersectionObserver(function(entries, obs) {
    entries.forEach(function(e) {
      if (e.isIntersecting) { e.target.classList.add('is-visible'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.2 }).observe(el);
});
</script>

{% schema %}
{
  "name": "LUCE CTA",
  "tag": "div",
  "class": "brand-luce-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore the full collection"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop LUCE"
    }
  ],
  "presets": [
    {
      "name": "LUCE CTA"
    }
  ]
}
{% endschema %}
