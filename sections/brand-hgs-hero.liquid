{{ 'brand-hgs.css' | asset_url | stylesheet_tag }}

<section class="brand-hgs hgs-hero" id="hgsHero-{{ section.id }}">
  <div class="hgs-hero__visual">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 2000 }}"
           alt="{{ section.settings.label | escape }}"
           loading="eager"
           width="2000"
           height="1200" />
    {%- else -%}
      <div class="hgs-hero__placeholder">Hero Visual</div>
    {%- endif -%}
  </div>
  <div class="hgs-hero__bg"></div>

  <div class="hgs-hero__content">
    {%- if section.settings.label != blank -%}
      <div class="hgs-hero__label">{{ section.settings.label | escape }}</div>
    {%- endif -%}
    <h1 class="hgs-hero__title">HOME<br>GROUND<br>STORE<span class="tm">&trade;</span></h1>
    {%- if section.settings.tagline != blank -%}
      <p class="hgs-hero__tagline">{{ section.settings.tagline | escape }}</p>
    {%- endif -%}
  </div>

  <div class="hgs-hero__year">{{ section.settings.year_text | default: 'Est. 2024 / Tokyo' | escape }}</div>
  <div class="hgs-hero__scroll"></div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var hero = document.getElementById('hgsHero-{{ section.id }}');
  if (!hero) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    hero.classList.add('is-visible');
    return;
  }
  setTimeout(function() { hero.classList.add('is-visible'); }, 200);
});
</script>

{% schema %}
{
  "name": "HGS Hero",
  "tag": "div",
  "class": "brand-hgs-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label text",
      "default": "Good Time Mall — Brand"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Streetwear rooted in comfort and self-expression."
    },
    {
      "type": "text",
      "id": "year_text",
      "label": "Year text",
      "default": "Est. 2024 / Tokyo"
    }
  ],
  "presets": [
    {
      "name": "HGS Hero"
    }
  ]
}
{% endschema %}
